---
import { site } from '../lib/site';
---

<section class="map-section" aria-label="Mapa de Barrio Bisquertt">
  <div class="map-frame">
    <iframe
      src={site.mapSrc}
      title="Mapa Barrio Bisquertt"
      loading="lazy"
      allowfullscreen
      referrerpolicy="no-referrer-when-downgrade"
    ></iframe>
  </div>
</section>

