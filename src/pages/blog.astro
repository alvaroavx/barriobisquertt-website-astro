---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentCard from '../components/ContentCard.astro';
import { orders, sortBySlugOrder } from '../lib/site';

const entries = sortBySlugOrder(await getCollection('historias'), orders.historias);
---

<BaseLayout title="Blog" description="Blog de Barrio Bisquertt.">
  <main>
    <header class="page-hero container">
      <p class="eyebrow">Barrio Bisquertt</p>
      <h1>Blog</h1>
    </header>
    <section class="container">
      <div class="card-grid">
        {entries.map((entry) => (
          <ContentCard
            href={entry.data.route}
            title={entry.data.title}
            description={entry.data.excerpt}
            image={entry.data.mainImage}
            date={entry.data.publishedOn}
            category={entry.data.category}
            variant="editorial"
          />
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

