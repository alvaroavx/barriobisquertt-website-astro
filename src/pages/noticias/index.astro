---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentCard from '../../components/ContentCard.astro';
import { orders, sortBySlugOrder } from '../../lib/site';

const entries = sortBySlugOrder(await getCollection('noticias'), orders.noticias);
---

<BaseLayout title="Noticias" description="Noticias de Barrio Bisquertt.">
  <main>
    <header class="page-hero container">
      <p class="eyebrow">Barrio Bisquertt</p>
      <h1>Noticias</h1>
    </header>
    <section class="container">
      <div class="card-grid">
        {entries.map((entry) => (
          <ContentCard
            href={entry.data.route}
            title={entry.data.title}
            description={entry.data.description}
            image={entry.data.mainImage}
            date={entry.data.publishedOn}
            category={entry.data.category}
            variant="news"
            containImage={entry.data.mainImage.publicPath?.toLowerCase().includes('afiche') || entry.data.mainImage.publicPath?.toLowerCase().includes('programacion')}
          />
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

