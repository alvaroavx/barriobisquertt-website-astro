---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SiteScripts from '../components/SiteScripts.astro';
import { site } from '../lib/site';
import '../styles/global.css';
import '../styles/layout.css';

interface Props {
  title?: string;
  description?: string | null;
  image?: string | null;
  hideHeader?: boolean;
}

const {
  title = site.name,
  description = site.description,
  image = null,
  hideHeader = false,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site || Astro.url.origin).toString();
const pageTitle = title === site.name ? site.name : `${title} - ${site.name}`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || site.description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/assets/barrio-bisquertt/mirror/img/favicon.ico" sizes="any" />
    {image && <meta property="og:image" content={image} />}
    <title>{pageTitle}</title>
  </head>
  <body>
    {!hideHeader && <Header currentPath={Astro.url.pathname} />}
    <slot />
    <Footer />
    <SiteScripts />
  </body>
</html>

